alias gdn='git diff --name-only'

export PYTHONDONTWRITEBYTECODE=1

bof() {
  cyclic -l "$(cyclic 200 | strace "./$1" 3>&1 1>&2 2>&3 3>&- | grep si_addr | sed -E 's/.*si_addr=(.*)}.*/\1/g')"
}

binfo() {
  NC='\033[1;0m'
  RED='\033[1;31m'
  GREEN='\033[1;32m'
  YELLOW='\033[1;33m'
  PURPLE='\033[1;35m'
  WHITE='\033[1;37m'
  pwnme="$1"
  checksec "${pwnme}"
  paste <(echo "${WHITE}FUNCTIONS/SYMBOLS${NC}"; rabin2 -qs "${pwnme}" | egrep -ve ' (0|1) ' -e imp -e ' _' | sort -k 1) /dev/null <(echo "${GREEN}STRINGS${NC}"; rabin2 -z "${pwnme}") | column -s $'\t' -tn
  echo "${YELLOW}LIBRARY FUNCTIONS${NC}"
  echo "${RED}Pwnable:${NC}"
  rabin2 -i "${pwnme}" | egrep '(gets|scanf|strcpy|strcat|strncat|malloc|system)' | cut -c5- | sed 's/scanf/scanf (one-byte overflow if field width is equal to buffer length)/' | sed 's/malloc/malloc (probably heap pwnable)/' | sed 's/system/system (probably a win function!!!)/'
  echo "${PURPLE}Leakable:${NC}"
  rabin2 -i "${pwnme}" | egrep '(read|strncpy|memcpy)' | cut -c5-
}

pygo() {
  local env_name
  env_name="${1:-venv}"
  source "${env_name}/bin/activate"
}

gogogadget() {
  pygo "$1"
}

pregister() {
  if [[ -z "${1:-}" ]]; then
    echo "Enter a file name"
  fi
  sudo nautilus /usr/bin &
}

picon() {
  if [[ -z "${1:-}" ]]; then
    echo "Enter a file name"
  fi
  sudo nautilus /usr/share/applications &
}

up() {
  local counter up_path

  if [[ -z "${1:-}" ]]; then
    echo "cd .."
    cd ..
    return 0
  fi

  counter="$1"
  if [[ "${counter}" =~ ^[0-9]+$ ]] && (( counter > 0 )); then
    up_path=""
    while (( counter > 0 )); do
      up_path="${up_path}../"
      counter=$((counter - 1))
    done
    echo "cd ${up_path}"
    cd "${up_path}"
    return 0
  fi

  echo 'Usage: up <n>'
  return 1
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

sua() {
  declare -A pkm
  local manager command_parts command_line

  pkm[yum]='yum update -y; yum clean all'
  pkm[aptitude]='aptitude update; aptitude upgrade -y'
  pkm[apt]='apt update; apt upgrade -y; apt autoremove -y'
  pkm[powerpill]='powerpill -Syu --noconfirm; pacman -Sc --noconfirm'
  pkm[pacman]='pacman -Syu --noconfirm; pacman -Sc --noconfirm'
  pkm[zypp]='zypp refresh -y; zypp update -y; zypp packages --unneeded'
  pkm[emerge]='emerge --sync; emerge --update --deep --with-bdeps=y @world'

  for manager command_line in ${(kv)pkm[@]}; do
    if command_exists "${manager}"; then
      echo "Using command ${command_line}"
      command_parts=("${(@s/; /)command_line}")
      for command_line in "${command_parts[@]}"; do
        echo "sudo ${command_line}"
        sudo ${=command_line}
      done
      return
    fi
  done

  echo 'Update command not known. Set for sua() in .aliases'
}

hps() (
  cd ~/.dotfiles

  if [[ $# -eq 0 ]]; then
    git push
    return
  fi

  if [[ $# -ne 1 ]]; then
    echo "usage:
    hps
    hps <commit message>"
    return
  fi

  if [[ -z "$(git status --untracked-files=no --porcelain)" ]]; then
    echo "Home config clean, no changes."
    return
  fi

  git add .
  git commit -m "$1"
  git push
  echo "Home config changes pushed."
)
