#!/usr/bin/env bash

if grep -qi Microsoft /proc/version; then
  echo "To use VS Code with WSL, install VS Code in Windows and remove the Linux package." 1>&2
  read -e -p "Do you want to continue anyway? [y/N] " YN
  [[ "${YN}" == "y" || "${YN}" == "Y" ]] || exit 1
fi

if [ "$(id -u)" = "0" ]; then
  for i in "$@"; do
    if [[ "${i}" == --user-data-dir || "${i}" == --user-data-dir=* || "${i}" == --file-write ]]; then
      CAN_LAUNCH_AS_ROOT=1
    fi
  done
  if [ -z "${CAN_LAUNCH_AS_ROOT:-}" ]; then
    echo "Starting VS Code as root requires --user-data-dir." 1>&2
    exit 1
  fi
fi

if [ ! -L "$0" ]; then
  VSCODE_PATH="$(dirname "$0")/.."
elif command -v readlink >/dev/null 2>&1; then
  VSCODE_PATH="$(dirname "$(readlink -f "$0")")/.."
else
  VSCODE_PATH="/usr/share/code"
fi

ELECTRON="${VSCODE_PATH}/code"
CLI="${VSCODE_PATH}/resources/app/out/cli.js"
ELECTRON_RUN_AS_NODE=1 "${ELECTRON}" "${CLI}" "$@"
